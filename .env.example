# Local app
HOST=127.0.0.1
PORT=3137
DATA_DIR=data

# Auth
AUTH_REQUIRED=1
# disabled: no account creation; approval: request access + approve link; open: public account creation.
SIGNUP_MODE=disabled
# Legacy flag: set to 1 only for local open signup testing when SIGNUP_MODE is unset.
SIGNUP_ENABLED=0
POCKETBASE_URL=http://127.0.0.1:8090

# Optional approval-mode notifications
PUBLIC_BASE_URL=http://127.0.0.1:3137
# ACCESS_APPROVAL_TOKEN=replace-with-a-long-random-secret
# TELEGRAM_BOT_TOKEN=replace-with-your-bot-token
# TELEGRAM_CHAT_ID=replace-with-your-chat-id

# Optional OpenClaw customer brain
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=replace-with-a-secret
# OPENCLAW_AGENT_ID=main

# Optional command customer brain
# CODEX_BRAIN_COMMAND=["node","scripts/codex-brain.mjs"]
# CODEX_MODEL=gpt-5.4-mini
